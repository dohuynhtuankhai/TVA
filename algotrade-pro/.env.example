# AlgoTrade Pro – Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Encryption key for API secrets at rest
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=your-generated-key-here

# Session signing key (optional — random generated if missing, but sessions won't survive restart)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# REQUIRED: Dashboard login credentials (set your own)
AUTH_USERNAME=
AUTH_PASSWORD=

# Redis (optional – falls back to in-memory if unavailable)
REDIS_URL=redis://localhost:6379/0

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false

# Optional: extra webhook auth. When set, /api/webhook requires the secret via
# either the `X-Webhook-Secret` header OR a `?secret=...` query parameter.
# TradingView cannot send headers, so use the query param in its webhook URL:
#   https://your-domain.com/api/webhook?secret=<this value>
WEBHOOK_SECRET=
