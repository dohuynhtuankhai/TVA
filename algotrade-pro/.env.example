# AlgoTrade Pro – Environment Configuration
# Copy this file to .env and fill in your values

# Encryption key for API secrets at rest (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_KEY=your-generated-key-here

# ── Authentication ───────────────────────────────────────────────
AUTH_USERNAME=dohuynhtuankhai
AUTH_PASSWORD=@Ab123456

# Redis (optional – install Redis locally or leave as default)
REDIS_URL=redis://localhost:6379/0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Optional: extra webhook auth (TradingView can send this as a header)
WEBHOOK_SECRET=
